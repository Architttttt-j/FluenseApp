# ─── Fluense Flutter App — Environment Variables Example ─────────────────────
# Rename this file to .env and fill in your actual values.
# This .env.example file is safe to commit to version control.

# ─── Backend ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:3000/api

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── App Info ─────────────────────────────────────────────────────────────────
APP_NAME=Fluense
APP_ENV=development
# APP_ENV options: development | staging | production
