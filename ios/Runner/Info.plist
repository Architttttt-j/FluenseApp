<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- ios/Runner/Info.plist — merge these keys into your existing Info.plist -->
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Fluense</string>

    <!-- Location permissions -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Fluense needs your location to record check-in and check-out for client visits.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>Fluense needs your location to record attendance and client visit locations.</string>
    <key>NSLocationAlwaysUsageDescription</key>
    <string>Fluense needs your location to record attendance and client visit locations.</string>

    <!-- Camera & Photo Library -->
    <key>NSCameraUsageDescription</key>
    <string>Fluense needs camera access to upload visit photos.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Fluense needs photo library access to update your profile picture.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Fluense needs to save photos to your library.</string>

    <!-- Maps -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>comgooglemaps</string>
        <string>tel</string>
        <string>https</string>
    </array>

    <!-- Google Maps API key — replace YOUR_MAPS_API_KEY -->
    <key>GMSApiKey</key>
    <string>YOUR_MAPS_API_KEY</string>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
</dict>
</plist>
